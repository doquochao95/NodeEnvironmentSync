# NAS - Node-Angular Sync Git Ignore

# 📦 Dependencies
node_modules/
npm-shrinkwrap.json

# 📂 NAS Core Data (Binaries - Huge files)
# Chúng ta sẽ không đẩy các bản Node thực tế lên Git
# Mỗi máy khi dùng chỉ cần chạy setup.ps1 hoặc tải lại bản cần thiết
versions/
current/

# 🛠️ Temporary files
temp_v*/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.trash/

# 🖥️ OS Specific
.DS_Store
Thumbs.db

# ⚙️ Environments & Settings (If any)
.env
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ⚙️ NES Local Config (Personal tool preferences)
nes_config.json
